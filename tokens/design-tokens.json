    },
    "geneva": {
      "$value": "\"Geneva-12\", system-ui, sans-serif"
    },
    "lucida": {
      "$value": "\"Inter\", system-ui, sans-serif"
    },
    "garamond": {
      "$value": "\"EB Garamond\", Georgia, serif"
    },
    "monaco": {
      "$value": "\"JetBrains Mono\", \"Menlo\", monospace"
    }
  },
